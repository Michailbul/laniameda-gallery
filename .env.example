# ---------------------------------------------------------------------------
# App + API env (loaded by Next.js app process)
# ---------------------------------------------------------------------------

# Public Convex deployment URL for browser clients (must start with https://).
NEXT_PUBLIC_CONVEX_URL=

# Convex deployment URL used by server routes/actions (usually same as above).
CONVEX_URL=

# Local Next.js dev port used by `bun run dev` (default 3317 if unset).
APP_PORT=3317

# Optional dev-only dashboard owner override for local gallery access.
# In production this is ignored.
NEXT_PUBLIC_DEV_OWNER_USER_ID=

# Named profile marker used by structured logs/docs (e.g. dev-sim, dev-telegram, prod-telegram).
APP_ENV_PROFILE=dev-telegram

# Optional canonical production host for alias redirects (Telegram login is origin-bound).
# Example: laniameda-galery.vercel.app
APP_CANONICAL_HOST=

# AI Gateway key for AI SDK runtime calls.
AI_GATEWAY_API_KEY=

# Gemini API key used for semantic embeddings.
GEMINI_API_KEY=

# Semantic indexing toggle and model settings.
SEMANTIC_EMBEDDINGS_ENABLED=false
SEMANTIC_EMBEDDING_MODEL=gemini-embedding-2-preview
SEMANTIC_EMBEDDING_DIMENSIONS=3072
SEMANTIC_SEARCH_LIMIT_DEFAULT=24

# Default runtime for /api/ai/* routes.
AI_RUNTIME_DEFAULT=ai_sdk

# Default text model for AI SDK runtime.
AI_TEXT_MODEL=anthropic/claude-sonnet-4.5

# Image model alias target for "nano_banana_pro".
AI_IMAGE_MODEL_NANO_BANANA=google/gemini-3-pro-image

# Image model alias target for "nano_banana_fast".
AI_IMAGE_MODEL_NANO_BANANA_FAST=google/gemini-2.5-flash-image

# Telegram bot token used for Telegram web login verification.
TELEGRAM_LOGIN_BOT_TOKEN=

# Telegram bot token used by Convex notifications ("✅ Saved" messages after ingest).
TELEGRAM_NOTIFY_BOT_TOKEN=

# Legacy single-token fallback (optional during migration).
# TELEGRAM_BOT_TOKEN=

# Telegram bot username used by the web login widget (without @).
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Optional: set to "write" only if login should also request bot DM permission.
# Omit for standard login-only auth to avoid Telegram confirmation-message prompts.
NEXT_PUBLIC_TELEGRAM_REQUEST_ACCESS=

# Secret token for validating Telegram bot webhook requests.
TELEGRAM_WEBHOOK_SECRET=

# Secret used to sign Telegram session JWT cookie (must be at least 32 chars).
SESSION_SECRET=

# Enables local Telegram-parity simulator endpoints/UI (no ngrok required when true).
DEV_TELEGRAM_SIM_ENABLED=false

# Allows /api/dev/telegram/simulate without auth when simulator is enabled.
DEV_TELEGRAM_SIM_AUTH_BYPASS=true

# Optional escape hatch to allow non-local hosts for dev simulator routes.
DEV_TELEGRAM_SIM_ALLOW_NON_LOCAL=false

# Local dev auth bypass for Telegram widget/domain issues (never enable in production).
NEXT_PUBLIC_DEV_AUTH_BYPASS_ENABLED=false
DEV_AUTH_BYPASS_ENABLED=false
DEV_AUTH_BYPASS_ALLOW_NON_LOCAL=false
DEV_AUTH_TELEGRAM_ID=
DEV_AUTH_FIRST_NAME=Dev
DEV_AUTH_USERNAME=

# Curated public gallery controls.
CURATION_ADMIN_SECRET=
CURATION_ADMIN_USER_IDS=
NEXT_PUBLIC_CURATION_ADMIN_USER_IDS=

# Agent token issuing. Set the same value in the Next.js app and Convex env.
AGENT_TOKEN_ISSUER_SECRET=

# Local MCP runtime config (used by `bun run mcp:gallery`, not by the app).
LANIAMEDA_GALLERY_API_URL=http://localhost:3317
LANIAMEDA_GALLERY_AGENT_TOKEN=

# Legacy Agent/CLI ingestion owner scope. Do not use for production multi-user agents.
KB_OWNER_USER_ID=
LOCAL_INGEST_OWNER_USER_ID=

# Chrome extension save endpoint auth.
# EXTENSION_API_TOKEN is the bearer token the extension sends.
# EXTENSION_OWNER_USER_ID is the Telegram ID assets created via the extension
# get scoped to (usually your own).
EXTENSION_API_TOKEN=
EXTENSION_OWNER_USER_ID=

# Cloudflare R2 — used to store video bytes (images stay on Convex).
# All five are required to enable R2 uploads. Without them, video uploads
# fall back to Convex storage.
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# ---------------------------------------------------------------------------
# Convex env mirrored into `convex/.env.local` for local parity when needed
# ---------------------------------------------------------------------------
