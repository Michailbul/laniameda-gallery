# ---------------------------------------------------------------------------
# App + API env (loaded by Next.js app process)
# ---------------------------------------------------------------------------

# Public Convex deployment URL for browser clients (must start with https://).
NEXT_PUBLIC_CONVEX_URL=

# Convex deployment URL used by server routes/actions (usually same as above).
CONVEX_URL=

# Local Next.js dev port used by `bun run dev` (default 3317 if unset).
APP_PORT=3317

# Optional dev-only dashboard owner override. Defaults to 278674008 when unset.
# In production this is ignored.
NEXT_PUBLIC_DEV_OWNER_USER_ID=

# Named profile marker used by structured logs/docs (e.g. dev-sim, dev-telegram, prod-telegram).
APP_ENV_PROFILE=dev-telegram

# WorkOS client ID for frontend AuthKit flows.
NEXT_PUBLIC_WORKOS_CLIENT_ID=

# WorkOS callback URL; must match WorkOS dashboard redirect URI exactly.
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# WorkOS/AuthKit cookie encryption password (required, min 32 chars).
WORKOS_COOKIE_PASSWORD=

# AI Gateway key for AI SDK runtime calls and Agent SDK live worker mode.
AI_GATEWAY_API_KEY=

# Default runtime for /api/ai/* routes: "ai_sdk" or "agent_worker".
AI_RUNTIME_DEFAULT=ai_sdk

# Must be "true" to allow worker dispatch path (required for Telegram MVP sprint).
ENABLE_AGENT_WORKER=true

# Default text model for AI SDK runtime.
AI_TEXT_MODEL=anthropic/claude-sonnet-4.5

# Image model alias target for "nano_banana_pro".
AI_IMAGE_MODEL_NANO_BANANA=google/gemini-3-pro-image

# Image model alias target for "nano_banana_fast".
AI_IMAGE_MODEL_NANO_BANANA_FAST=google/gemini-2.5-flash-image

# Base URL of agent worker service (local or deployed).
AGENT_WORKER_URL=http://127.0.0.1:8797

# Shared HMAC secret between app and worker for dispatch/cancel signatures.
AGENT_WORKER_SHARED_SECRET=

# Telegram webhook secret token; Telegram sends this in x-telegram-bot-api-secret-token.
TELEGRAM_WEBHOOK_SECRET=

# Max allowed webhook payload size in bytes.
TELEGRAM_WEBHOOK_MAX_BODY_BYTES=1000000

# Max time (ms) to read webhook body before request is rejected.
TELEGRAM_WEBHOOK_BODY_TIMEOUT_MS=30000

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Public HTTPS origin where Telegram can reach your app (no trailing /api path).
# Example: https://abc123.ngrok-free.app
TELEGRAM_WEBHOOK_PUBLIC_URL=

# Enables local Telegram-parity simulator endpoints/UI (no ngrok required when true).
DEV_TELEGRAM_SIM_ENABLED=false

# Allows /api/dev/telegram/simulate without auth when simulator is enabled.
DEV_TELEGRAM_SIM_AUTH_BYPASS=true

# Optional escape hatch to allow non-local hosts for dev simulator routes.
DEV_TELEGRAM_SIM_ALLOW_NON_LOCAL=false

# Optional reserved ngrok domain for stable public URL in `bun run dev:telegram`.
NGROK_DOMAIN=

# ---------------------------------------------------------------------------
# Convex auth env (must exist in Convex dashboard; optional local mirror)
# ---------------------------------------------------------------------------

# WorkOS client ID used by convex/auth.config.ts for JWT audience checks.
WORKOS_CLIENT_ID=

# ---------------------------------------------------------------------------
# Agent worker env (loaded by agent-worker process)
# ---------------------------------------------------------------------------

# Logical worker identifier for run ownership/events.
AGENT_WORKER_ID=agent-worker-local

# Local worker dev port used by `bun run worker:dev` (default 8797 if unset).
WORKER_PORT=8797

# Optional legacy direct Anthropic key (not used by default worker gateway path).
ANTHROPIC_API_KEY=

# Anthropic-compatible gateway base URL used by Agent SDK worker.
AGENT_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh

# Daytona API key for sandbox provisioning.
DAYTONA_API_KEY=

# Daytona API base URL.
DAYTONA_API_URL=

# Daytona target/workspace identifier.
DAYTONA_TARGET=

# Claude model name used by Agent SDK worker.
AGENT_MODEL=claude-sonnet-4-5

# Max agent turns per run.
AGENT_MAX_TURNS=8

# If "true", worker skips live Claude execution and emits deterministic dummy prompt packages.
# Set to "false" only after AI_GATEWAY_API_KEY is configured.
AGENT_DUMMY_MODE=true

# If "true", Telegram runs use Agent SDK streaming runtime first.
AGENT_STREAMING_MODE=true

# If "true", worker falls back to legacy single-mode when streaming fails.
AGENT_STREAMING_SINGLE_FALLBACK=true

# If "true", auto-enable Skill tool support for project SKILL.md loading.
AGENT_SKILLS_ENABLED=true

# Filesystem setting sources loaded by Agent SDK ("project", "user", "local").
AGENT_SETTING_SOURCES=project

# Working directory passed to Claude Agent SDK execution.
AGENT_WORKSPACE_CWD=

# Optional extra absolute directories Claude can read/write (comma-separated).
AGENT_ADDITIONAL_DIRECTORIES=

# Comma-separated allowed tools for Agent SDK runs.
AGENT_ALLOWED_TOOLS=Read,Write,Edit,Bash,Glob,Grep,LS

# Max Telegram attachment size (bytes) to download/stage in worker.
TELEGRAM_MEDIA_MAX_BYTES=20000000

# Max bytes for direct multimodal blocks (image/pdf) sent inline to Agent SDK.
TELEGRAM_MEDIA_DIRECT_BLOCK_MAX_BYTES=5000000

# Node binary command used inside Daytona sandbox process sessions.
AGENT_SANDBOX_NODE_COMMAND=node

# Auto-stop timeout for Daytona sandboxes (minutes).
DAYTONA_AUTO_STOP_MINUTES=10
