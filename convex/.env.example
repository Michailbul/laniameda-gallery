# Local Convex env parity file (for `bunx convex dev` workflows).
# Copy to convex/.env.local to mirror key Convex-only vars used in local dev.
# This does NOT replace setting env vars in the Convex dashboard for prod.

# Telegram bot token used by Convex internal notification actions.
TELEGRAM_NOTIFY_BOT_TOKEN=

# Gemini API key used by Convex semantic indexing/search actions.
GEMINI_API_KEY=

# Semantic search configuration.
SEMANTIC_EMBEDDINGS_ENABLED=false
SEMANTIC_EMBEDDING_MODEL=gemini-embedding-2-preview
SEMANTIC_EMBEDDING_DIMENSIONS=3072
SEMANTIC_SEARCH_LIMIT_DEFAULT=24

# Admin / curator authorization (also read by the Next.js side; mirror here
# so Convex mutations can validate admin requests against the same allowlist).
CURATION_ADMIN_SECRET=
CURATION_ADMIN_USER_IDS=
KB_OWNER_USER_ID=

# Must match the Next.js app env var so session-backed routes can issue
# multi-user agent tokens without exposing owner selection to callers.
AGENT_TOKEN_ISSUER_SECRET=

# Cloudflare R2 — required so Convex can store video bytes there.
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# Legacy single-token fallback (optional during migration).
# TELEGRAM_BOT_TOKEN=
