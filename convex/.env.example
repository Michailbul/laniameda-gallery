# Local Convex env parity file (for `bunx convex dev` workflows).
# Copy to convex/.env.local to mirror key auth vars used by convex/auth.config.ts.
# This does NOT replace setting env vars in the Convex dashboard.

# WorkOS client ID used as JWT audience in Convex auth config.
WORKOS_CLIENT_ID=

# Telegram bot token used by Convex internal notification actions.
TELEGRAM_BOT_TOKEN=
