{
  "name": "prompt-storager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run ingest:local && next dev --webpack -p ${APP_PORT:-3317}",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "ingest:local": "bun scripts/ingest-local-assets.ts",
    "env:doctor": "bun scripts/env-doctor.ts --mode dev-telegram",
    "env:doctor:sim": "bun scripts/env-doctor.ts --mode dev-sim",
    "env:doctor:telegram": "bun scripts/env-doctor.ts --mode dev-telegram",
    "env:doctor:prod": "bun scripts/env-doctor.ts --mode prod-telegram",
    "worker:dev": "PORT=${WORKER_PORT:-8797} bun run agent-worker/server.ts",
    "worker:start": "NODE_ENV=production PORT=${WORKER_PORT:-8797} bun run agent-worker/server.ts",
    "dev:sim": "bun scripts/dev-stack.ts --mode dev-sim",
    "dev:telegram": "bun scripts/dev-stack.ts --mode dev-telegram",
    "dev:all": "bun scripts/dev-stack.ts --mode dev-all",
    "telegram:webhook:set": "bun scripts/telegram-webhook.ts set",
    "telegram:webhook:info": "bun scripts/telegram-webhook.ts info",
    "telegram:webhook:delete": "bun scripts/telegram-webhook.ts delete"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.45",
    "@ai-sdk/react": "^3.0.87",
    "@anthropic-ai/claude-agent-sdk": "^0.2.39",
    "@base-ui/react": "^1.1.0",
    "@convex-dev/workos": "^0.0.1",
    "@daytonaio/sdk": "^0.141.0",
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.4",
    "@workos-inc/authkit-nextjs": "^2.13.0",
    "ai": "^6.0.85",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.31.6",
    "geist": "^1.7.0",
    "jimp": "^1.6.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.5",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
